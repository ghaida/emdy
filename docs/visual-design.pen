            {
              "type": "text",
              "id": "OMGcL",
              "name": "id3",
              "fill": "#71717A",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "A typographic ligature — 'Em' in bold serif, a nod to the em dash and the typographic unit. The red variant adds the editor's mark energy. At small sizes it reads as a confident letterform; at large sizes it reveals the craft of the serif details.",
              "lineHeight": 1.6,
              "fontFamily": "IBM Plex Sans",
              "fontSize": 14
            }
          ]
        },
        {
          "type": "line",
