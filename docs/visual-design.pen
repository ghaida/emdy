              "name": "id2",
              "fill": "#71717A",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "A reading mark or folded page corner — something that suggests bookmarks and quiet attention. Soft radius, warm tones. The mark should feel like an object you'd find on a bedside table, not in a dock full of productivity apps.",
              "lineHeight": 1.7,
              "fontFamily": "IBM Plex Serif",
              "fontSize": 14
            }
